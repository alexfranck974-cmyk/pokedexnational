    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "build:pokedex": "ts-node --project tsconfig.scripts.json scripts/build-pokemon-data.ts",
    "sync:tcg": "ts-node --project tsconfig.scripts.json scripts/sync-tcg-cards.ts",
    "sync:tcgdex": "ts-node --project tsconfig.scripts.json scripts/sync-tcgdex-cards.ts"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-native-svg|@shopify/flash-list)"
