{
  "name": "pokedexnational",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@shopify/flash-list": "^2.3.2",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.2",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "jest-expo": "^57.0.2",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "build:pokedex": "ts-node --project tsconfig.scripts.json scripts/build-pokemon-data.ts",
    "sync:tcg": "ts-node --project tsconfig.scripts.json scripts/sync-tcg-cards.ts"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-native-svg|@shopify/flash-list)"
    ]
  },
  "private": true
}
